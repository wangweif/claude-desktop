# Claude Code API Configuration
# Copy this file to .env and fill in your values

# API Token (from open.bigmodel.cn or Anthropic)
ANTHROPIC_AUTH_TOKEN=your-api-token-here

# API Base URL
# For GLM models: https://open.bigmodel.cn/api/anthropic
# For Claude models: https://api.anthropic.com
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# GitHub Personal Access Token (for GitHub MCP server)
GITHUB_PERSONAL_ACCESS_TOKEN=

# Tavily API Key (for Tavily search MCP server)
TAVILY_API_KEY=
